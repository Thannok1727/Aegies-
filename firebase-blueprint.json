{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Topic": {
      "title": "Topic",
      "description": "A blog topic with its workflow stages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "progress": { "type": "number" },
        "stages": {
          "type": "object",
          "properties": {
            "writing": {
              "type": "object",
              "properties": {
                "completed": { "type": "boolean" },
                "content": { "type": "string" }
              }
            },
            "image": {
              "type": "object",
              "properties": {
                "completed": { "type": "boolean" },
                "imageUrl": { "type": "string" }
              }
            },
            "posting": {
              "type": "object",
              "properties": {
                "completed": { "type": "boolean" },
                "finalNotes": { "type": "string" }
              }
            }
          }
        },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "status", "progress", "stages"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/topics/{topicId}": {
      "schema": "Topic",
      "description": "Blog topics and their progress"
    }
  }
}
